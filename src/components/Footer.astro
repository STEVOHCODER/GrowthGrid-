---
const currentYear = new Date().getFullYear();
---
<footer class="bg-slate-900 text-slate-300 py-12">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <div>
        <h3 class="text-white font-bold text-lg mb-4">Finance & Wealth Hub</h3>
        <p class="text-slate-400">High-precision financial tools and strategies for building long-term wealth.</p>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-4 text-emerald-400">Quick Links</h4>
        <ul class="space-y-2">
          <li><a href="/#tools" class="hover:text-white transition">Mortgage Calculator</a></li>
          <li><a href="/#tools" class="hover:text-white transition">Wealth Forecaster</a></li>
          <li><a href="/blog" class="hover:text-white transition">Wealth Guides</a></li>
          <li><a href="/about" class="hover:text-white transition">About Our Mission</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-4 text-emerald-400">Support & Legal</h4>
        <ul class="space-y-2">
          <li><a href="/contact" class="hover:text-white transition">Contact Us</a></li>
          <li><a href="/privacy" class="hover:text-white transition">Privacy Policy</a></li>
          <li><a href="/terms" class="hover:text-white transition">Terms of Service</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-slate-800 mt-12 pt-8 text-center text-sm">
      <p>&copy; {currentYear} Finance & Wealth Hub. All rights reserved.</p>
    </div>
  </div>
</footer>
