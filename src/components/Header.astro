---
import ThemeToggle from './ThemeToggle.jsx';
---
<header class="bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 py-4 sticky top-0 z-50">
  <div class="container mx-auto px-4 flex justify-between items-center">
    <a href="/" class="text-xl font-bold text-emerald-600 dark:text-emerald-400 uppercase tracking-tight">FinanceWise</a>
    <nav class="hidden md:flex space-x-8">
      <a href="/#tools" class="text-slate-700 dark:text-slate-200 hover:text-emerald-600 dark:hover:text-emerald-400 font-bold transition">Tools</a>
      <a href="/blog" class="text-slate-700 dark:text-slate-200 hover:text-emerald-600 dark:hover:text-emerald-400 font-bold transition">Guides</a>
      <a href="/about" class="text-slate-700 dark:text-slate-200 hover:text-emerald-600 dark:hover:text-emerald-400 font-bold transition">About</a>
    </nav>
    <div class="flex items-center gap-4">
      <ThemeToggle client:load />
      <a href="/#tools" class="bg-emerald-600 text-white px-5 py-2 rounded-lg font-bold hover:bg-emerald-700 transition shadow-md">Get Started</a>
    </div>
  </div>
</header>
