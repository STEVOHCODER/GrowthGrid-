---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Wealth Building Guides">
  <Header />
  <main class="py-20 bg-white dark:bg-slate-950 transition-colors">
    <div class="container mx-auto px-4 max-w-4xl">
      <h1 class="text-4xl font-extrabold mb-12 text-slate-900 dark:text-white">Expert Wealth Guides</h1>
      <div class="space-y-12">
        {posts.map((post) => (
          <article class="group">
            <a href={`/blog/${post.slug}`} class="block">
              <p class="text-sm font-bold text-indigo-600 dark:text-indigo-400 mb-2">{post.data.pubDate.toLocaleDateString()}</p>
              <h2 class="text-2xl font-bold mb-4 text-slate-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition">{post.data.title}</h2>
              <p class="text-slate-600 dark:text-slate-400 leading-relaxed">{post.data.description}</p>
            </a>
          </article>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
